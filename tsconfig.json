{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./",
    "resolveJsonModule": true,
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "typeRoots": ["./node_modules/@types", "./types"]
  },
  "include": [
    "server.js",
    "server.ts",
    "controllers/**/*",
    "routes/**/*",
    "models/**/*",
    "middleware/**/*",
    "utils/**/*",
    "db/**/*",
    "errors/**/*",
    "types/**/*"
  ],
  "exclude": ["node_modules", "client", "next-client", "dist"]
}